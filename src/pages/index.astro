---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Rishab Kashyap"
	description="Personal website of Rishab Kashyap, MS CS student and researcher at Arizona State University's MPS Lab."
>
	<!-- Home (Hero Section) -->
	<section id="home" class="hero-section">
		<div class="hero-glow"></div>
		<div class="container hero-container">
			<div class="badge-container">
				<span class="status-badge">
					<span class="pulse-dot"></span> AI/ML Engineer
				</span>
			</div>

			<div class="profile-image-container">
				<img
					src="/profile_pic.jpeg"
					alt="Rishab Kashyap"
					class="profile-pic"
				/>
			</div>

			<h1 class="hero-title">
				Hi, I'm <span id="typed-name" class="text-gradient"></span><span
					class="typing-cursor">|</span
				>
			</h1>
			<h2 class="hero-subtitle-heading">
				AI/ML Engineer at American Express, Alumni, MSCS at Arizona
				State University
			</h2>

			<p class="hero-subtitle">| Just your average programming bloke |</p>

			<div class="hero-actions">
				<a href="/projects" class="btn btn-primary">
					View My Projects
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><path d="M5 12h14M12 5l7 7-7 7"></path></svg
					>
				</a>
				<a href="/experience" class="btn btn-secondary"
					>See Experience</a
				>
			</div>
		</div>
	</section>

	<!-- Directory Spotlight Section -->
	<section class="spotlight-section">
		<div class="container">
			<div class="section-header">
				<h2 class="section-title">My Portfolio</h2>
			</div>

			<div class="directory-grid">
				<a href="/education" class="card spotlight-card glass">
					<div class="card-icon">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							><path d="M22 10v6M2 10l10-5 10 5-10 5z"
							></path><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"
							></path></svg
						>
					</div>
					<h3>Education</h3>
					<p>
						Learn about my Masters at ASU, Bachelors at PES
						University, and relevant graduate-level coursework.
					</p>
					<span class="card-link">View Education &rarr;</span>
				</a>

				<a href="/experience" class="card spotlight-card glass">
					<div class="card-icon">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							><rect
								x="2"
								y="7"
								width="20"
								height="14"
								rx="2"
								ry="2"></rect><path
								d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"
							></path></svg
						>
					</div>
					<h3>Work Experience</h3>
					<p>
						Browse roles as an AI Engineer, Graduate Student
						Assistant, TA, researcher at ASU, and Secure Multi-Party
						computation intern at IISc.
					</p>
					<span class="card-link">View Experience &rarr;</span>
				</a>

				<a href="/projects" class="card spotlight-card glass">
					<div class="card-icon">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							><polygon points="12 2 2 7 12 12 22 7 12 2"
							></polygon><polyline points="2 17 12 22 22 17"
							></polyline><polyline points="2 12 12 17 22 12"
							></polyline></svg
						>
					</div>
					<h3>Projects</h3>
					<p>
						Read about ADAPT (Asymmetric Device Parallel Training),
						URL Classification ensembles, and Kepler habitability
						models.
					</p>
					<span class="card-link">View Projects &rarr;</span>
				</a>

				<a href="/certifications" class="card spotlight-card glass">
					<div class="card-icon">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							><circle cx="12" cy="8" r="7"></circle><polyline
								points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"
							></polyline></svg
						>
					</div>
					<h3>Publications</h3>
					<p>
						Check out my research publications in IEEE-CSDE, MLDS,
						and other journals, alongside academic co-authors.
					</p>
					<span class="card-link">View Publications &rarr;</span>
				</a>
			</div>
		</div>
	</section>
</Layout>

<style>
	/* Hero Section */
	.hero-section {
		position: relative;
		padding: 9rem 0 6rem;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		overflow: hidden;
		border-bottom: 1px solid var(--border-color);
	}

	.hero-glow {
		position: absolute;
		top: -10%;
		left: 50%;
		transform: translateX(-50%);
		width: 700px;
		height: 450px;
		background: radial-gradient(
			circle,
			rgba(59, 130, 246, 0.12) 0%,
			rgba(30, 64, 175, 0.04) 60%,
			transparent 100%
		);
		filter: blur(90px);
		z-index: -1;
		pointer-events: none;
	}

	.hero-container {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.badge-container {
		margin-bottom: 2rem;
		opacity: 0;
		animation: fadeInUp 0.6s ease forwards;
	}

	.status-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		border-radius: 9999px;
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--text-secondary);
	}

	.pulse-dot {
		width: 8px;
		height: 8px;
		background-color: var(--accent-light);
		border-radius: 50%;
		position: relative;
	}

	.pulse-dot::after {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		border-radius: 50%;
		background-color: var(--accent-light);
		animation: pulse 1.8s infinite;
	}

	.profile-image-container {
		margin-bottom: 1.5rem;
		opacity: 0;
		animation: fadeInUp 0.6s ease 0.05s forwards;
	}

	.profile-pic {
		width: 160px;
		height: 160px;
		border-radius: 50%;
		object-fit: cover;
		border: 3px solid var(--bg-secondary);
		box-shadow: 0 4px 20px rgba(59, 130, 246, 0.2);
		transition:
			transform var(--transition-smooth),
			box-shadow var(--transition-smooth),
			border-color var(--transition-smooth);
	}

	.profile-pic:hover {
		transform: scale(1.05);
		border-color: var(--accent-light);
		box-shadow: 0 8px 30px rgba(59, 130, 246, 0.4);
	}

	.hero-title {
		font-size: 3.75rem;
		line-height: 1.15;
		margin-bottom: 1rem;
		font-family: var(--font-sans);
		font-weight: 800;
		letter-spacing: -0.03em;
		opacity: 0;
		animation: fadeInUp 0.6s ease 0.15s forwards;
	}

	.typing-cursor {
		display: inline-block;
		color: var(--accent-light);
		animation: blink 0.8s step-end infinite;
		font-weight: 300;
		margin-left: 2px;
	}

	@keyframes blink {
		from,
		to {
			color: transparent;
		}
		50% {
			color: var(--accent-light);
		}
	}

	.hero-subtitle-heading {
		font-size: 1.35rem;
		font-weight: 600;
		color: var(--text-primary);
		max-width: 720px;
		line-height: 1.3;
		margin-bottom: 1.5rem;
		opacity: 0;
		animation: fadeInUp 0.6s ease 0.25s forwards;
	}

	.hero-subtitle {
		font-size: 1.1rem;
		max-width: 640px;
		margin-bottom: 2.5rem;
		line-height: 1.6;
		color: var(--text-secondary);
		opacity: 0;
		animation: fadeInUp 0.6s ease 0.35s forwards;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		opacity: 0;
		animation: fadeInUp 0.6s ease 0.45s forwards;
	}

	/* About Overview */
	.about-overview-section {
		padding: 5rem 0;
		border-bottom: 1px solid var(--border-color);
	}

	.about-grid {
		padding: 3rem;
		border-radius: 20px;
		border: 1px solid var(--border-color);
		max-width: 900px;
		margin: 0 auto;
	}

	.about-content h2 {
		font-size: 2rem;
		margin-bottom: 1.5rem;
	}

	.about-content p {
		font-size: 1.05rem;
		line-height: 1.7;
		margin-bottom: 1.25rem;
		color: var(--text-secondary);
	}

	.about-content p strong {
		color: var(--text-primary);
	}

	.quick-info {
		display: flex;
		gap: 2rem;
		margin-top: 2rem;
		font-size: 1rem;
		color: var(--text-primary);
		flex-wrap: wrap;
	}

	.quick-info a {
		color: var(--accent-light);
		font-weight: 600;
	}

	.quick-info a:hover {
		color: var(--accent);
	}

	/* Skills Section */
	.skills-section {
		padding: 6rem 0;
		background: var(--bg-secondary);
		border-bottom: 1px solid var(--border-color);
	}

	.section-header {
		text-align: center;
		margin-bottom: 4.5rem;
	}

	.section-title {
		font-size: 2.25rem;
		margin-bottom: 0.75rem;
	}

	.section-desc {
		color: var(--text-secondary);
		font-size: 1.05rem;
	}

	.skills-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2.5rem;
	}

	.skills-card {
		padding: 2.5rem;
		border-radius: 20px;
		border: 1px solid var(--border-color);
	}

	.skills-card h3 {
		font-size: 1.4rem;
		margin-bottom: 1.5rem;
		color: var(--text-primary);
		border-bottom: 2px solid var(--border-color);
		padding-bottom: 0.5rem;
	}

	.badges-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.skill-badge {
		padding: 0.5rem 1rem;
		border-radius: 8px;
		background: var(--bg-primary);
		border: 1px solid var(--border-color);
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--text-secondary);
		transition: all var(--transition-fast);
	}

	.skill-badge:hover {
		border-color: var(--accent-light);
		color: var(--text-primary);
		transform: translateY(-2px);
	}

	/* Spotlight Section */
	.spotlight-section {
		padding: 6rem 0;
	}

	.directory-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2rem;
	}

	.spotlight-card {
		padding: 2.5rem 2rem;
		border-radius: 20px;
		border: 1px solid var(--border-color);
		transition:
			transform var(--transition-smooth),
			border-color var(--transition-smooth),
			box-shadow var(--transition-smooth);
		display: flex;
		flex-direction: column;
		gap: 1rem;
		text-decoration: none;
	}

	.spotlight-card:hover {
		transform: translateY(-5px);
		border-color: var(--accent-light);
		box-shadow: 0 12px 30px rgba(59, 130, 246, 0.08);
	}

	.card-icon {
		width: 3rem;
		height: 3rem;
		border-radius: 12px;
		background: var(--accent-gradient);
		display: flex;
		align-items: center;
		justify-content: center;
		color: #ffffff;
		margin-bottom: 0.5rem;
	}

	.spotlight-card h3 {
		font-size: 1.35rem;
		color: var(--text-primary);
	}

	.spotlight-card p {
		font-size: 0.95rem;
		color: var(--text-secondary);
		line-height: 1.6;
		flex-grow: 1;
	}

	.card-link {
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--accent-light);
		margin-top: 0.5rem;
	}

	.spotlight-card:hover .card-link {
		color: var(--accent);
	}

	/* Animations */
	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(15px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes pulse {
		0% {
			transform: scale(0.95);
			box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.7);
		}
		70% {
			transform: scale(1);
			box-shadow: 0 0 0 6px rgba(59, 130, 246, 0);
		}
		100% {
			transform: scale(0.95);
			box-shadow: 0 0 0 0 rgba(59, 130, 246, 0);
		}
	}

	/* Responsive */
	@media (max-width: 1024px) {
		.hero-title {
			font-size: 3.25rem;
		}

		.directory-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.skills-grid {
			grid-template-columns: 1fr;
		}

		.skills-card {
			grid-column: span 1 !important;
		}
	}

	@media (max-width: 768px) {
		.hero-section {
			padding: 7rem 0 5rem;
		}

		.hero-title {
			font-size: 2.5rem;
		}

		.hero-subtitle-heading {
			font-size: 1.15rem;
		}

		.hero-actions {
			flex-direction: column;
			width: 100%;
			max-width: 280px;
		}

		.about-grid {
			padding: 2rem 1.5rem;
		}

		.quick-info {
			flex-direction: column;
			gap: 0.75rem;
		}
	}
</style>

<script>
	const text = "Rishab Kashyap.";
	const typedSpan = document.getElementById("typed-name");
	let index = 0;

	function typeEffect() {
		if (typedSpan && index < text.length) {
			typedSpan.textContent += text.charAt(index);
			index++;
			setTimeout(typeEffect, 120);
		}
	}

	// Start typing after initial fade-in has completed
	setTimeout(typeEffect, 800);
</script>
