---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Publications & Credentials | Rishab Kashyap" description="Academic publications, conference proceedings, and research details of Rishab Kashyap.">
	<section class="certifications-page">
		<div class="container">
			<div class="page-header">
				<h1 class="page-title text-gradient">Publications & Research</h1>
				<p class="page-desc">Academic publications, conference proceedings, and active research directions.</p>
			</div>

			<div class="cert-grid">
				<!-- Publications -->
				<div class="cert-column glass" style="grid-column: span 2;">
					<h2 class="sub-section-title">
						<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"></path><path d="M6 6h10M6 10h10M6 14h10"></path></svg>
						Academic Publications
					</h2>
					<div class="cert-list">
						<!-- Paper 1 -->
						<div class="cert-item">
							<div class="cert-details">
								<div class="cert-header-meta">
									<h4>ADAPT: Asymmetric Device Adaptive Parallel Training for Small-Scale Heterogeneous Systems</h4>
									<span class="citation-badge">Thesis Research</span>
								</div>
								<span class="cert-issuer">Masters Thesis / MPS Lab • 2024 - 2025</span>
								<p>Investigated asymmetric parallel training strategies spanning model, pipeline, and data distribution formats on heterogeneous GPU environments. Formulated dynamic scheduling costs to minimize cross-device latency.</p>
							</div>
						</div>

						<!-- Paper 2 -->
						<div class="cert-item">
							<div class="cert-details">
								<div class="cert-header-meta">
									<h4>Detection of Malicious URLs Through an Ensemble of Machine Learning Techniques</h4>
									<span class="citation-badge">Cited by 15</span>
								</div>
								<span class="cert-issuer">Published in IEEE-CSDE Conference Proceedings • 2021</span>
								<p>Formulated a cascading, high-accuracy url classification schema. Deployed 6 independent attribute-specific feature classifiers passing logical inputs to a final ensemble decision tree.</p>
							</div>
						</div>

						<!-- Paper 3 -->
						<div class="cert-item">
							<div class="cert-details">
								<div class="cert-header-meta">
									<h4>Movie Success Prediction and Performance Comparison Using Various Statistical Approaches</h4>
									<span class="citation-badge">Cited by 3</span>
								</div>
								<span class="cert-issuer">Published in MLDS Conference Proceedings • 2021</span>
								<p>Evaluated and compared mathematical accuracies of distinct classifiers (regression models, neural layers, decision trees) predicting financial yield success metrics based on production features.</p>
							</div>
						</div>

						<!-- Paper 4 -->
						<div class="cert-item">
							<div class="cert-details">
								<div class="cert-header-meta">
									<h4>A Comprehensive Study on Various Statistical Techniques for Prediction of Movie Success</h4>
									<span class="citation-badge">Cited by 3</span>
								</div>
								<span class="cert-issuer">Published in International Journal of Artificial Intelligence & Applications (IJAIA) • 2021</span>
								<p>Conducted extensive correlation audits and feature importance mappings to analyze box office predictability metrics based on cast strength, release windows, and budget ratios.</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Professional Certifications -->
				<div class="cert-column glass" style="grid-column: span 2;">
					<h2 class="sub-section-title">
						<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg>
						Professional Certifications
					</h2>
					
					<div class="cert-groups-grid">
						<!-- Group 1: Google Cloud -->
						<div class="cert-group-box">
							<h3>
								<span class="group-icon">☁️</span>
								Cloud Engineering (Google Cloud)
							</h3>
							<ul class="cert-item-list">
								<li>
									<div class="cert-item-info">
										<a href="https://coursera.org/share/e353c83faa09b668ffbc59cf551b439f" target="_blank" rel="noopener noreferrer" class="cert-verify-link">
											<strong>Cloud Engineering with Google Cloud</strong>
											<span class="specialization-tag">Specialization</span>
										</a>
										<span class="cert-org">Google Cloud</span>
									</div>
								</li>
								<li>
									<div class="cert-item-info">
										<a href="https://coursera.org/share/f112ba7c4a9b2163986f6369b2e76cf6" target="_blank" rel="noopener noreferrer" class="cert-verify-link">
											Reliable Google Cloud Infrastructure: Design and Process
										</a>
										<span class="cert-org">Google Cloud</span>
									</div>
								</li>
								<li>
									<div class="cert-item-info">
										<a href="https://coursera.org/share/32e926d0235400ecaba5c106a0072b00" target="_blank" rel="noopener noreferrer" class="cert-verify-link">
											Elastic Google Cloud Infrastructure: Scaling and Automation
										</a>
										<span class="cert-org">Google Cloud</span>
									</div>
								</li>
								<li>
									<div class="cert-item-info">
										<a href="https://coursera.org/share/8f34386dddb7899dd5487defcb2f8dba" target="_blank" rel="noopener noreferrer" class="cert-verify-link">
											Essential Google Cloud Infrastructure: Core Services
										</a>
										<span class="cert-org">Google Cloud</span>
									</div>
								</li>
								<li>
									<div class="cert-item-info">
										<a href="https://coursera.org/share/aac007fcb9fe7f886a4b94aac3f50928" target="_blank" rel="noopener noreferrer" class="cert-verify-link">
											Essential Google Cloud Infrastructure: Foundation
										</a>
										<span class="cert-org">Google Cloud</span>
									</div>
								</li>
								<li>
									<div class="cert-item-info">
										<a href="https://coursera.org/share/3b0a5d6eb899141a30ff077d06d5a5a8" target="_blank" rel="noopener noreferrer" class="cert-verify-link">
											Google Cloud Fundamentals: Core Infrastructure
										</a>
										<span class="cert-org">Google Cloud</span>
									</div>
								</li>
							</ul>
						</div>

						<!-- Group 2: Applied Cryptography & Git -->
						<div class="cert-group-box">
							<h3>
								<span class="group-icon">🔒</span>
								Applied Cryptography & Tools
							</h3>
							<ul class="cert-item-list">
								<li>
									<div class="cert-item-info">
										<a href="https://coursera.org/share/e1428f264e7c458e6240c365b79b3e28" target="_blank" rel="noopener noreferrer" class="cert-verify-link">
											<strong>Applied Cryptography Specialization</strong>
											<span class="specialization-tag">Specialization</span>
										</a>
										<span class="cert-org">University of Colorado System</span>
									</div>
								</li>
								<li>
									<div class="cert-item-info">
										<a href="https://coursera.org/share/6c2993d7dead16b85a496ada94ac81f8" target="_blank" rel="noopener noreferrer" class="cert-verify-link">
											Asymmetric Cryptography and Key Management
										</a>
										<span class="cert-org">University of Colorado System</span>
									</div>
								</li>
								<li>
									<div class="cert-item-info">
										<a href="https://coursera.org/share/227328123936dca188661bd05faf8a33" target="_blank" rel="noopener noreferrer" class="cert-verify-link">
											Symmetric Cryptography
										</a>
										<span class="cert-org">University of Colorado System</span>
									</div>
								</li>
								<li>
									<div class="cert-item-info">
										<a href="https://coursera.org/share/6a0bc9674d4baaaf098892989138f322" target="_blank" rel="noopener noreferrer" class="cert-verify-link">
											Mathematical Foundations for Cryptography
										</a>
										<span class="cert-org">University of Colorado System</span>
									</div>
								</li>
								<li>
									<div class="cert-item-info">
										<a href="https://coursera.org/share/f40ce9d52cede405bf77d4a7001f3e8a" target="_blank" rel="noopener noreferrer" class="cert-verify-link">
											Classical Cryptosystems and Core Concepts
										</a>
										<span class="cert-org">University of Colorado System</span>
									</div>
								</li>
								<li>
									<div class="cert-item-info">
										<a href="https://coursera.org/share/527c53e9c9347bc5c4c144b3312ed1a2" target="_blank" rel="noopener noreferrer" class="cert-verify-link">
											Introduction to Git and GitHub
										</a>
										<span class="cert-org">Google</span>
									</div>
								</li>
							</ul>
						</div>
					</div>
				</div>

				<!-- Research Fields -->
				<div class="cert-column glass" style="grid-column: span 2;">
					<h2 class="sub-section-title">
						<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
						Research Interests & Directions
					</h2>
					<div class="interests-grid">
						<div class="interest-card">
							<h4>Machine Learning Accelerators</h4>
							<p>Exploring specialized hardware compilers, scheduling layers, and performance optimizations for large language model workloads.</p>
						</div>
						<div class="interest-card">
							<h4>Symmetric & Asymmetric SMPC</h4>
							<p>Developing Secure Multi-Party Computation protocols enabling collaborative machine learning over encrypted, privacy-safe pipelines.</p>
						</div>
						<div class="interest-card">
							<h4>Quantum Computing Simulators</h4>
							<p>Researching NISQ quantum hardware limitations, state vector simulations, and algorithms under the guidance of MPS lab collaborators.</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.certifications-page {
		padding: 5rem 0;
	}

	.page-header {
		text-align: center;
		margin-bottom: 5rem;
	}

	.page-title {
		font-size: 3rem;
		margin-bottom: 1rem;
		font-weight: 800;
	}

	.page-desc {
		color: var(--text-secondary);
		font-size: 1.15rem;
		max-width: 600px;
		margin: 0 auto;
	}

	/* Certifications & Publications Grid */
	.cert-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 3rem;
		align-items: start;
	}

	.cert-column {
		padding: 3rem 2.5rem;
		border-radius: 20px;
		border: 1px solid var(--border-color);
	}

	.sub-section-title {
		font-size: 1.6rem;
		margin-bottom: 2.5rem;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		color: var(--text-primary);
		border-bottom: 2px solid var(--border-color);
		padding-bottom: 0.75rem;
	}

	.sub-section-title svg {
		color: var(--accent-light);
	}

	.cert-list {
		display: flex;
		flex-direction: column;
		gap: 2.25rem;
	}

	.cert-item {
		display: flex;
		gap: 1rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--border-color);
	}

	.cert-item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.cert-header-meta {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1.5rem;
		flex-wrap: wrap;
		margin-bottom: 0.25rem;
	}

	.cert-details h4 {
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--text-primary);
		line-height: 1.4;
		max-width: 80%;
	}

	.citation-badge {
		font-size: 0.75rem;
		font-weight: 700;
		padding: 0.25rem 0.75rem;
		background: var(--bg-primary);
		border: 1px solid var(--accent-light);
		color: var(--accent);
		border-radius: 9999px;
		white-space: nowrap;
	}

	:root[data-theme="dark"] .citation-badge {
		color: var(--accent-light);
		border-color: var(--accent);
	}

	.cert-issuer {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--accent-light);
		display: block;
		margin-bottom: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.cert-details p {
		font-size: 0.95rem;
		color: var(--text-secondary);
		line-height: 1.6;
	}

	/* Research fields */
	.interests-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.interest-card {
		padding: 1.5rem;
		border-radius: 12px;
		background: var(--bg-primary);
		border: 1px solid var(--border-color);
	}

	.interest-card h4 {
		font-size: 1.1rem;
		margin-bottom: 0.5rem;
		color: var(--text-primary);
	}

	.interest-card p {
		font-size: 0.95rem;
		color: var(--text-secondary);
		line-height: 1.5;
	}

	/* Responsive */
	@media (max-width: 1024px) {
		.cert-grid {
			grid-template-columns: 1fr;
			gap: 2.5rem;
		}

		.interests-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
	}

	@media (max-width: 768px) {
		.certifications-page {
			padding: 4rem 0;
		}

		.page-title {
			font-size: 2.5rem;
		}

		.cert-column {
			padding: 1.75rem;
		}

		.sub-section-title {
			font-size: 1.4rem;
		}

		.cert-header-meta {
			flex-direction: column;
			gap: 0.5rem;
		}

		.cert-details h4 {
			max-width: 100%;
			font-size: 1.15rem;
		}
	}

	/* Certifications Group Grid */
	.cert-groups-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2.5rem;
	}

	.cert-group-box h3 {
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--text-primary);
		margin-bottom: 1.5rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		border-bottom: 1px solid var(--border-color);
		padding-bottom: 0.5rem;
	}

	.cert-item-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.cert-item-list li {
		padding-left: 0;
		position: relative;
	}

	.cert-item-info {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.cert-verify-link {
		font-size: 1rem;
		font-weight: 600;
		color: var(--text-primary);
		transition: color var(--transition-fast);
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.cert-verify-link:hover {
		color: var(--accent-light);
	}

	.specialization-tag {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		background: rgba(59, 130, 246, 0.1);
		color: var(--accent);
		padding: 0.15rem 0.5rem;
		border-radius: 4px;
		border: 1px solid var(--accent-light);
	}

	:root[data-theme="dark"] .specialization-tag {
		color: var(--accent-light);
	}

	.cert-org {
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--accent-light);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	@media (max-width: 900px) {
		.cert-groups-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
</style>
