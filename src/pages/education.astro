---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Education | Rishab Kashyap"
	description="My academic history at Arizona State University, PES University, and coursework."
>
	<section class="education-page">
		<div class="container">
			<div class="page-header">
				<h1 class="page-title text-gradient">Education</h1>
				<p class="page-desc">
					My academic history, research focuses, and theoretical
					foundations.
				</p>
			</div>

			<div class="education-layout">
				<!-- Academic Timeline -->
				<div class="timeline-container">
					<h2 class="sub-section-title">Academic Timeline</h2>
					<div class="timeline">
						<!-- ASU -->
						<div class="timeline-item glass">
							<div class="timeline-badge">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="16"
									height="16"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									><path d="M22 10v6M2 10l10-5 10 5-10 5z"
									></path><path
										d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"
									></path></svg
								>
							</div>
							<div class="timeline-date">2022 - 2026</div>
							<h3 class="timeline-title">
								Masters of Science in Computer Science
							</h3>
							<h4 class="timeline-subtitle">
								Arizona State University
							</h4>
							<div class="timeline-location">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="14"
									height="14"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									class="location-icon"
									><path
										d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
									></path><circle cx="12" cy="10" r="3"
									></circle></svg
								>
								Tempe, Arizona, USA
							</div>
							<p class="timeline-quote">"!!! Go Devils !!!"</p>
							<p class="timeline-content">
								Pursued a Thesis as part of my Master's Degree.
								GPA: <strong>3.46</strong>. Actively worked on
								research projects and accelerator publications
								as part of the MPS Lab. Specialized in
								Artificial Intelligence, Machine Learning and
								Computer Architecture.
							</p>
						</div>

						<!-- PES University -->
						<div class="timeline-item glass">
							<div class="timeline-badge">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="16"
									height="16"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									><path d="M22 10v6M2 10l10-5 10 5-10 5z"
									></path><path
										d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"
									></path></svg
								>
							</div>
							<div class="timeline-date">2018 - 2022</div>
							<h3 class="timeline-title">
								Bachelors of Science in Computer Science
							</h3>
							<h4 class="timeline-subtitle">PES University</h4>
							<div class="timeline-location">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="14"
									height="14"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									class="location-icon"
									><path
										d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
									></path><circle cx="12" cy="10" r="3"
									></circle></svg
								>
								Bengaluru, India
							</div>
							<p class="timeline-quote">
								"Perseverance, Excellence, Service"
							</p>
							<p class="timeline-content">
								Completed my degree with an aggregate GPA of <strong
									>8.12</strong
								>. Participated in numerous hackathons and
								ideathons. Served as part of the ACM Student
								Chapter hosting programming competitions. Member
								of the PESU South Basketball team. Co-authored
								three publications under Dr. R Bharathi and
								Prof. Ananthanagu U.
							</p>
						</div>

						<!-- Deeksha -->
						<div class="timeline-item glass">
							<div class="timeline-badge">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="16"
									height="16"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									><path d="M22 10v6M2 10l10-5 10 5-10 5z"
									></path><path
										d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"
									></path></svg
								>
							</div>
							<div class="timeline-date">2016 - 2018</div>
							<h3 class="timeline-title">High School</h3>
							<h4 class="timeline-subtitle">
								Deeksha Center for Learning
							</h4>
							<div class="timeline-location">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="14"
									height="14"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									class="location-icon"
									><path
										d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
									></path><circle cx="12" cy="10" r="3"
									></circle></svg
								>
								Bengaluru, India
							</div>
							<p class="timeline-quote">
								"Study Hard, But Study Smart"
							</p>
							<p class="timeline-content">
								Completed my 11th and 12th grades with rigorous
								training integrated with ACE. Graduated with an
								overall percentage of <strong>96%</strong>.
								Member of the school basketball team and the IIT
								preparation batch.
							</p>
						</div>

						<!-- The Brigade School -->
						<div class="timeline-item glass">
							<div class="timeline-badge">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="16"
									height="16"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									><path d="M22 10v6M2 10l10-5 10 5-10 5z"
									></path><path
										d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"
									></path></svg
								>
							</div>
							<div class="timeline-date">2006 - 2016</div>
							<h3 class="timeline-title">Primary Schooling</h3>
							<h4 class="timeline-subtitle">
								The Brigade School
							</h4>
							<div class="timeline-location">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="14"
									height="14"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									class="location-icon"
									><path
										d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
									></path><circle cx="12" cy="10" r="3"
									></circle></svg
								>
								Bengaluru, India
							</div>
							<p class="timeline-quote">
								"O nanna chetana, aaguni aniketana" / "O my
								spirit, transcend all boundaries"
							</p>
							<p class="timeline-content">
								Completed grades 1 to 10 with a 10th grade GPA
								of <strong>9.2</strong>. Participated in
								numerous olympiads, science fairs, theater
								plays, and fests. Active player in intra-school
								sports (Basketball, Volleyball, Football,
								Athletics) and MUN.
							</p>
						</div>
					</div>
				</div>

				<!-- Relevant Coursework Sidebar -->
				<div class="coursework-container glass">
					<h2 class="sub-section-title">Relevant Coursework</h2>
					<div class="courses-list">
						<div class="course-card">
							<h4>Machine Learning & AI</h4>
							<p>
								Statistical Machine Learning, Privacy in Machine
								Learning, Artificial Intelligence, Knowledge
								Representation and Reasoning.
							</p>
						</div>
						<div class="course-card">
							<h4>Systems & Architecture</h4>
							<p>
								Computer Architecture, Advanced Operating
								Systems, Distributed Systems.
							</p>
						</div>
						<div class="course-card">
							<h4>Advanced Computing</h4>
							<p>Quantum Computing, Combinatorial Algorithms.</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.education-page {
		padding: 5rem 0;
	}

	.page-header {
		text-align: center;
		margin-bottom: 5rem;
	}

	.page-title {
		font-size: 3rem;
		margin-bottom: 1rem;
		font-weight: 800;
	}

	.page-desc {
		color: var(--text-secondary);
		font-size: 1.15rem;
		max-width: 600px;
		margin: 0 auto;
	}

	.education-layout {
		display: grid;
		grid-template-columns: 3fr 2fr;
		gap: 3rem;
		align-items: start;
	}

	.sub-section-title {
		font-size: 1.75rem;
		margin-bottom: 2.5rem;
		color: var(--text-primary);
		border-bottom: 2px solid var(--border-color);
		padding-bottom: 0.75rem;
	}

	/* Timeline */
	.timeline {
		position: relative;
		padding-left: 2.5rem;
	}

	.timeline::before {
		content: "";
		position: absolute;
		left: 8px;
		top: 0.5rem;
		bottom: 0.5rem;
		width: 2px;
		background: var(--bg-tertiary);
	}

	.timeline-item {
		position: relative;
		padding: 2rem;
		border-radius: 16px;
		margin-bottom: 2.5rem;
		border: 1px solid var(--border-color);
		transition:
			transform var(--transition-smooth),
			border-color var(--transition-smooth);
	}

	.timeline-item:last-child {
		margin-bottom: 0;
	}

	.timeline-item:hover {
		transform: translateX(5px);
		border-color: var(--accent-light);
	}

	.timeline-badge {
		position: absolute;
		left: calc(-2.5rem - 8px);
		top: 2rem;
		width: 2rem;
		height: 2rem;
		border-radius: 50%;
		background: var(--bg-secondary);
		border: 2px solid var(--accent-light);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--accent-light);
		z-index: 2;
	}

	.timeline-date {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--accent-light);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.5rem;
	}

	.timeline-title {
		font-size: 1.35rem;
		font-weight: 700;
		margin-bottom: 0.25rem;
	}

	.timeline-subtitle {
		font-size: 1.05rem;
		font-weight: 600;
		color: var(--text-secondary);
		margin-bottom: 0.25rem;
	}

	.timeline-location {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--text-secondary);
		margin-bottom: 0.75rem;
	}

	.location-icon {
		color: var(--accent-light);
		flex-shrink: 0;
	}

	.timeline-quote {
		font-size: 0.95rem;
		font-style: italic;
		color: var(--text-muted);
		margin-bottom: 0.75rem;
	}

	.timeline-content {
		color: var(--text-secondary);
		line-height: 1.6;
	}

	/* Coursework Sidebar */
	.coursework-container {
		padding: 2.5rem;
		border-radius: 20px;
		border: 1px solid var(--border-color);
	}

	.courses-list {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.course-card {
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--border-color);
	}

	.course-card:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.course-card h4 {
		font-size: 1.15rem;
		margin-bottom: 0.5rem;
		color: var(--text-primary);
	}

	.course-card p {
		font-size: 0.95rem;
		color: var(--text-secondary);
		line-height: 1.5;
	}

	/* Responsive */
	@media (max-width: 1024px) {
		.education-layout {
			grid-template-columns: 1fr;
			gap: 3rem;
		}
	}

	@media (max-width: 768px) {
		.education-page {
			padding: 4rem 0;
		}

		.page-title {
			font-size: 2.5rem;
		}

		.timeline {
			padding-left: 1.75rem;
		}

		.timeline::before {
			left: 4px;
		}

		.timeline-badge {
			left: calc(-1.75rem - 4px);
			width: 1.5rem;
			height: 1.5rem;
			top: 2.25rem;
		}

		.timeline-badge svg {
			width: 12px;
			height: 12px;
		}

		.coursework-container {
			padding: 1.75rem;
		}
	}
</style>
