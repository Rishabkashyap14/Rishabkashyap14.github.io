---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Experience | Rishab Kashyap" description="My professional history as a researcher, GSA, teaching assistant, and research intern.">
	<section class="experience-page">
		<div class="container">
			<div class="page-header">
				<h1 class="page-title text-gradient">Work Experience</h1>
				<p class="page-desc">My professional and academic experience in machine learning systems, data analysis, and teaching.</p>
			</div>

			<div class="experience-layout">
				<div class="timeline">
					<!-- AI/ML Engineer -->
					<div class="timeline-item glass">
						<div class="timeline-badge">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
						</div>
						<div class="timeline-date">April 2026 - Present</div>
						<h3 class="timeline-title">AI/ML Engineer</h3>
						<h4 class="timeline-subtitle">American Express • Phoenix, Arizona</h4>
						<p class="timeline-quote">Labs team working on utilizing LLMs to improve banking applications</p>
						<ul class="timeline-bullets">
							<li>Working on new ways to introduce agentic pipelines in banking and credit card related applications.</li>
							<li>Performing Data Science and Data Engineering utilizing Google Cloud Platform.</li>
						</ul>
					</div>

					<!-- Graduate Student Researcher -->
					<div class="timeline-item glass">
						<div class="timeline-badge">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
						</div>
						<div class="timeline-date">August 2023 - February 2026</div>
						<h3 class="timeline-title">Graduate Student Researcher</h3>
						<h4 class="timeline-subtitle">Arizona State University (MPS Lab)</h4>
						<p class="timeline-quote">Research under the guidance of Dr. Aviral Shrivastava</p>
						<ul class="timeline-bullets">
							<li>Conducted research on <strong>Optimal Parallel Training strategies</strong> (Data, Model, and Pipeline parallelism) for ML workloads as part of my Master's Thesis.</li>
							<li>Assisted in research on Quantum Computing execution on NISQ devices.</li>
							<li>Participated in competitive systems challenges, including the TinyML competition and the Waymo Dataset Challenge.</li>
							<li>Reviewed papers and researched performance optimizations for ML Accelerators.</li>
						</ul>
					</div>

					<!-- Computer Architecture GSA -->
					<div class="timeline-item glass">
						<div class="timeline-badge">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
						</div>
						<div class="timeline-date">August 2023 - May 2025</div>
						<h3 class="timeline-title">Computer Architecture GSA</h3>
						<h4 class="timeline-subtitle">Arizona State University</h4>
						<p class="timeline-quote">Graduate Student Assistant for CSE 420 and CSE 520 Computer Architecture courses</p>
						<ul class="timeline-bullets">
							<li>Assisted under the guidance of Dr. Aviral Shrivastava and Dr. Hokeun Kim.</li>
							<li>Responsible for grading student examinations, code, and project assignments.</li>
							<li>Co-created coursework content, exam formats, and practice problems.</li>
							<li>Delivered targeted lectures on specialized topics and held revision classes for student groups.</li>
						</ul>
					</div>

					<!-- TA for BIO194 -->
					<div class="timeline-item glass">
						<div class="timeline-badge">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
						</div>
						<div class="timeline-date">August 2023 - May 2025</div>
						<h3 class="timeline-title">Teaching Assistant for BIO194</h3>
						<h4 class="timeline-subtitle">Arizona State University</h4>
						<p class="timeline-quote">Academic Associate for the BIO194 SOLUR Prep Course</p>
						<ul class="timeline-bullets">
							<li>Created course content, programming worksheets, and assignments under the guidance of Dr. Susan Holechek.</li>
							<li>Delivered lectures focusing on Data Science methodologies and R programming applied to biological data structures.</li>
							<li>Assisted with assignment corrections and grading final project presentations.</li>
						</ul>
					</div>

					<!-- Student Researcher - Holechek Lab -->
					<div class="timeline-item glass">
						<div class="timeline-badge">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
						</div>
						<div class="timeline-date">January 2024 - December 2024</div>
						<h3 class="timeline-title">Student Researcher</h3>
						<h4 class="timeline-subtitle">The Holechek Lab</h4>
						<p class="timeline-quote">Obesity analysis among the Hispanic community</p>
						<ul class="timeline-bullets">
							<li>Conducted data analysis on sensitive demographic health datasets under the guidance of Dr. Susan Holechek.</li>
							<li>Utilized datasets provided by the All of Us Research Program (funded by the NIH) to identify risk indicators.</li>
						</ul>
					</div>

					<!-- Research Intern -->
					<div class="timeline-item glass">
						<div class="timeline-badge">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
						</div>
						<div class="timeline-date">October 2021 - July 2022</div>
						<h3 class="timeline-title">Research Intern</h3>
						<h4 class="timeline-subtitle">Indian Urban Data Exchange (IUDX), IISc Bengaluru</h4>
						<p class="timeline-quote">Secure Multiparty Machine Learning Computation</p>
						<ul class="timeline-bullets">
							<li>Completed a 10-month research internship at an IISc-based startup under Dr. Abhay Sharma and Dr. Anshoo Tandon.</li>
							<li>Researched multi-party encryption techniques enabling secure, collaborative model training on sensitive distributed datasets.</li>
							<li>Developed system tools in C++ using Boost libraries to implement Secure Multi-Party Computing (SMPC) and Homomorphic Encryption.</li>
							<li>Responsible for risk evaluation, software testing, protocol evaluation, and mathematical proof validation.</li>
						</ul>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.experience-page {
		padding: 5rem 0;
	}

	.page-header {
		text-align: center;
		margin-bottom: 5rem;
	}

	.page-title {
		font-size: 3rem;
		margin-bottom: 1rem;
		font-weight: 800;
	}

	.page-desc {
		color: var(--text-secondary);
		font-size: 1.15rem;
		max-width: 600px;
		margin: 0 auto;
	}

	.experience-layout {
		max-width: 800px;
		margin: 0 auto;
	}

	/* Timeline */
	.timeline {
		position: relative;
		padding-left: 2.5rem;
	}

	.timeline::before {
		content: '';
		position: absolute;
		left: 8px;
		top: 0.5rem;
		bottom: 0.5rem;
		width: 2px;
		background: var(--bg-tertiary);
	}

	.timeline-item {
		position: relative;
		padding: 2.5rem 2rem;
		border-radius: 16px;
		margin-bottom: 3rem;
		border: 1px solid var(--border-color);
		transition: transform var(--transition-smooth), border-color var(--transition-smooth);
	}

	.timeline-item:last-child {
		margin-bottom: 0;
	}

	.timeline-item:hover {
		transform: translateX(5px);
		border-color: var(--accent-light);
	}

	.timeline-badge {
		position: absolute;
		left: calc(-2.5rem - 8px);
		top: 2.5rem;
		width: 2rem;
		height: 2rem;
		border-radius: 50%;
		background: var(--bg-secondary);
		border: 2px solid var(--accent-light);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--accent-light);
		z-index: 2;
	}

	.timeline-date {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--accent-light);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.5rem;
	}

	.timeline-title {
		font-size: 1.5rem;
		font-weight: 700;
		margin-bottom: 0.25rem;
	}

	.timeline-subtitle {
		font-size: 1.1rem;
		font-weight: 600;
		color: var(--text-secondary);
		margin-bottom: 0.5rem;
	}

	.timeline-quote {
		font-size: 0.9rem;
		font-style: italic;
		color: var(--text-muted);
		margin-bottom: 1.25rem;
	}

	.timeline-bullets {
		margin-left: 1.25rem;
		color: var(--text-secondary);
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		line-height: 1.6;
	}

	.timeline-bullets li {
		font-size: 1rem;
	}

	.timeline-bullets li strong {
		color: var(--text-primary);
	}

	/* Responsive */
	@media (max-width: 768px) {
		.experience-page {
			padding: 4rem 0;
		}

		.page-title {
			font-size: 2.5rem;
		}

		.timeline {
			padding-left: 1.75rem;
		}

		.timeline::before {
			left: 4px;
		}

		.timeline-badge {
			left: calc(-1.75rem - 4px);
			width: 1.5rem;
			height: 1.5rem;
			top: 2.75rem;
		}

		.timeline-badge svg {
			width: 12px;
			height: 12px;
		}

		.timeline-item {
			padding: 1.75rem 1.5rem;
		}
	}
</style>
